programa
{
	
	funcao inicio()
	{
	inteiro anos,meses,dias,idade_dias

	escreva(" Quantos anos você tem:)
	leia(anos)

	esreva("Quantos meses vc tem:)
	leia(meses)


	esreva("Quantos dias vc tem:)
	leia(dias)

	idade_dias= (anos*365)+ (meses*30)+dias

     escreva("sua idade em dias é", idade_dias)
	
	}
}
